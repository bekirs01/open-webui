# Vite dev: tarayıcı API tabanı (varsayılan http://localhost:9090). Backend farklı porttaysa açın.
# PUBLIC_WEBUI_BACKEND_URL=http://127.0.0.1:9090

# Ollama URL for the backend to connect
# The path '/ollama' will be redirected to the specified backend URL
OLLAMA_BASE_URL='http://localhost:11434'

OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# MWS GPT (OpenAI-compatible). Merge adds this URL to OpenAI connections at startup when enabled.
# If MWS gives you a new base URL, set it here and in Admin → Connections (must match).
MWS_GPT_ENABLED=false
MWS_GPT_API_BASE_URL=https://api.gpt.mws.ru/v1
MWS_GPT_API_KEY=
MWS_GPT_DEFAULT_TEXT_MODEL=llama-3.3-70b-instruct
MWS_GPT_DEFAULT_CODE_MODEL=qwen3-coder-480b-a35b
MWS_GPT_DEFAULT_VISION_MODEL=qwen3-vl-30b-a3b-instruct
# Auto “draw / generate image” uses this when /models ids don’t match exactly; MWS merge sets IMAGE_GENERATION_MODEL from it
MWS_GPT_DEFAULT_IMAGE_MODEL=qwen-image
MWS_GPT_DEFAULT_AUDIO_MODEL=whisper-turbo-local
MWS_GPT_DEFAULT_EMBEDDING_MODEL=bge-m3
# Chat-time image generation (/images); set false to disable UI + pipeline
ENABLE_IMAGE_GENERATION=true
MWS_GPT_AUTO_ROUTING=true
# Auto: tiered text model selection (simple/medium/hard) + orchestration metadata
MWS_GPT_ORCHESTRATION=true
# Auto: vision→text ve kod→inceleme gibi çok adımlı iç iş akışları (false: tek model)
MWS_AUTO_MULTI_MODEL=true
# Auto + zor kod: taslak + gözden geçirici (iki iç çağrı)
MWS_AUTO_CODE_REVIEW=false
# Auto + görsel ek: önce VL, sonra metin sentez
MWS_AUTO_VISION_SYNTHESIS=true
# UI "Deep thinking" açıkken görsel üretimde boyut (örn. qwen-image için 1024x1024)
MWS_DEEP_THINKING_IMAGE_SIZE=1024x1024
# Deep thinking: metin için taslak→parlatma ikinci geçişi (çok adımlı Auto)
MWS_DEEP_THINKING_MULTI=true
# Auto preflight: second model receives full chat history. Optional max tokens cap (empty = no cap; reserved for future use)
# MWS_AUTO_PREFLIGHT_MAX_HISTORY_TOKENS=
# Prepend concise assistant policy for MWS-tagged chat completions
MWS_INJECT_QUALITY_POLICY=true
# Full workspace system prompt (workspace_system_prompt.py); false = legacy short MWS policy only
WORKSPACE_ASSISTANT_PROMPT_ENABLED=true
# Son kullanıcı mesajına göre tek dil/script kilidi ve isteğe bağlı temizlik (output_language_guard.py)
OUTPUT_LANGUAGE_LOCK_ENABLED=true
OUTPUT_LANGUAGE_SANITIZE=true
# Modelin ara ara ürettiği anlamsız kod/token çorbası paragraflarını kaldır (heuristik)
OUTPUT_TOKEN_SOUP_STRIP=true
# Türkçe özel harf (ç ğ ı İ ö ş ü) içeren sorgularda ek yazım koruma bloğu
TURKISH_ORTHOGRAPHY_HINT_ENABLED=true
# Export/conversion: PDF, PNG, JPEG, CSV, ZIP (builtin tools + server-side pipeline)
MWS_EXPORT_ENABLED=true
# Image prompt translation: all image generation requests translated to English for better results
MWS_IMAGE_PROMPT_FORCE_ENGLISH=true
# Restrict routing to team model IDs (see backend/open_webui/utils/mws_gpt/team_registry.py)
MWS_TEAM_ALLOWLIST_ONLY=true
# false = show embedding models in chat model list (with embedding label in UI)
MWS_HIDE_EMBEDDING_FROM_CHAT=false

# User long-term memories (vector DB + chat context injection). Also togglable in Admin → Settings.
ENABLE_MEMORIES=true
# How many memory snippets to inject per request (max 32 in middleware)
USER_MEMORY_TOP_K=10
# Long-term memory: post-turn LLM extraction (false to disable server-side auto extract)
LONG_TERM_MEMORY_AUTO_EXTRACT=true
# Optional override for extraction model (defaults to TASK_MODEL / first chat model)
# LONG_TERM_MEMORY_TASK_MODEL=
LONG_TERM_MEMORY_MIN_CONFIDENCE=0.45
LONG_TERM_MEMORY_DEDUPE_THRESHOLD=0.88
LONG_TERM_MEMORY_EXTRACTION_MAX_USER_CHARS=4000
LONG_TERM_MEMORY_EXTRACTION_MAX_ASSISTANT_CHARS=8000
# How many user+assistant pairs to extract per turn (batch extraction; default 3)
LONG_TERM_MEMORY_BATCH_PAIRS=3
# Semantic dedup: cosine similarity threshold (0-1; higher = stricter; requires vector DB)
# LONG_TERM_MEMORY_SEMANTIC_DEDUPE_THRESHOLD=0.92
# Retrieval: vector score interpretation (true = distance 0-2; false = similarity 0-1)
LTM_VECTOR_SCORE_IS_DISTANCE=true
# Retrieval: exponential half-life for recency decay (days)
LTM_RECENCY_HALF_LIFE_DAYS=60
# Same-folder chats: shared long-term memory scope + sibling chat snippets (set false to disable)
FOLDER_SHARED_MEMORY=true
# FOLDER_PEER_CONTEXT_MAX_BYTES=8000
# FOLDER_PEER_MAX_SIBLINGS=6
# Cross-chat: compact snapshot + “continue / import” (set false to disable APIs + prompt block)
ENABLE_CROSS_CHAT_CONTEXT=true
# Optional: model id for snapshot LLM (defaults to TASK_MODEL)
# CROSS_CHAT_SNAPSHOT_MODEL=
# CROSS_CHAT_SNAPSHOT_MAX_HISTORY_CHARS=14000
# CROSS_CHAT_PROMPT_MAX_CHARS=4500
# Web: backend ENABLE_WEB_SEARCH açılır; Admin → Settings’te arama API (ör. Tavily) anahtarını ekleyin.
MWS_ENABLE_WEB_SEARCH=true
# Her sohbet isteğinde web araması özelliğini aç (false: yalnızca UI’dan açılırsa)
MWS_INJECT_WEB_SEARCH_FEATURE=true
# smart: çizimde web zorunlu değil; saat/araştırma/güncel bilgi gibi durumlarda enjekte edilir. always|never
MWS_WEB_SEARCH_INJECT_MODE=smart
# Boş bırakılırsa merge duckduckgo atar (anahtarsız). Örn: tavily + TAVILY_API_KEY
MWS_WEB_SEARCH_ENGINE=
WEB_SEARCH_ENGINE=duckduckgo

# MTS yarışması: tüm modellere ortak sistem promptu (backend/open_webui/utils/mts_competition_system_prompt.py)
MTS_COMPETITION_SYSTEM_PROMPT_ENABLED=false
# MTS_COMPETITION_SYSTEM_PROMPT="Özel kısa prompt (çok satır için MTS_COMPETITION_SYSTEM_PROMPT_FILE kullanın)"
# MTS_COMPETITION_SYSTEM_PROMPT_FILE=/path/to/mts_rules.txt

# AUTOMATIC1111_BASE_URL="http://localhost:7860"

# For production, you should only need one host as
# fastapi serves the svelte-kit built frontend and backend from the same host and port.
# To test with CORS locally, you can set something like
# CORS_ALLOW_ORIGIN='http://localhost:1000;http://localhost:9090'
CORS_ALLOW_ORIGIN='*'

# For production you should set this to match the proxy configuration (127.0.0.1)
FORWARDED_ALLOW_IPS='*'

# DO NOT TRACK
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# Shared real-time chat (collab WebSocket). Frontend reads PUBLIC_COLLAB_WS_URL.
# Local (default, no change needed):
# PUBLIC_COLLAB_WS_URL=ws://localhost:4000

# Production — set this to your deployed WS server URL:
# PUBLIC_COLLAB_WS_URL=wss://your-collab-server.railway.app